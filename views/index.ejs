<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QuizArena - Interactive Quiz Platform</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body class="d-flex flex-column align-items-center justify-content-center position-relative overflow-hidden">

  <div class="position-absolute top-0 start-0 w-100 h-100 overflow-hidden z-n1" style="opacity: 0.05">
    <i class="bi bi-controller text-white position-absolute" style="top:10%;left:10%;transform:rotate(-15deg);font-size:5rem"></i>
    <i class="bi bi-patch-question-fill text-white position-absolute" style="top:20%;right:15%;transform:rotate(25deg);font-size:4rem"></i>
    <i class="bi bi-trophy-fill text-white position-absolute" style="bottom:15%;left:20%;transform:rotate(-10deg);font-size:6rem"></i>
    <i class="bi bi-rocket-takeoff-fill text-white position-absolute" style="bottom:25%;right:10%;transform:rotate(45deg);font-size:5rem"></i>
  </div>

  <div class="text-center mb-4">
    <h1 class="display-1 fw-bolder mb-2 text-white" style="font-size:4.5rem;text-shadow:0 5px 15px rgba(0,0,0,0.4);">
      <span class="title-highlight">Quiz</span>Arena
    </h1>
    <p class="fs-5 fw-light text-white opacity-75">Join the arena. Test your knowledge. Claim victory.</p>
  </div>

  <div class="glass-card mx-auto w-100" style="max-width:450px;">
    <div class="text-center mb-4">
      <h3>Join Game</h3>
      <hr class="w-25 mx-auto border-info border-2 opacity-100">
    </div>
    <form action="/join" method="POST">
      <div class="mb-4">
        <label class="form-label">Enter Join Code</label>
        <input type="text" name="code" class="form-control form-control-lg text-center fw-bold text-uppercase"
          placeholder="e.g. A1B2C3" required style="font-size:1.5rem;letter-spacing:2px;" maxlength="6" autocomplete="off">
      </div>
      <div class="mb-4">
        <label class="form-label">Your Nickname</label>
        <input type="text" name="name" class="form-control form-control-lg" placeholder="Cool Player" required maxlength="20" autocomplete="off">
      </div>
      <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold py-3 fs-5 shadow-sm">
        ENTER ARENA <i class="bi bi-play-circle ms-2"></i>
      </button>
    </form>
  </div>

  <div class="position-absolute bottom-0 w-100 text-center p-4">
    <a href="/login" class="text-light text-decoration-none" style="opacity:0.6;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.6'">Teacher / Admin Login</a>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
