<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QuizArena - Host Quiz</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-gradient text-light min-vh-100">

<div class="container py-5">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Host: <%= quiz.quiz_title %></h2>
    <a href="/dashboard" class="btn btn-outline-light">Back to Dashboard</a>
  </div>

  <div class="row g-4">
    <div class="col-md-8">
      <div class="glass-card p-5 text-center h-100 d-flex flex-column justify-content-center">
        <h3 class="mb-4 text-warning">Join Code:
          <span class="fw-bold display-3 d-block mt-2"><%= quiz.quiz_code %></span>
        </h3>
        <p class="fs-5 mb-5 opacity-75">Players join at <strong><%= process.env.APP_URL || 'your-app.onrender.com' %></strong></p>

        <form method="POST" action="/start-quiz/<%= quiz.id %>">
          <% if (quiz.status === 'pending') { %>
            <input type="hidden" name="action" value="start">
            <button type="submit" class="btn btn-success btn-lg px-5 shadow-lg">Start Quiz Now</button>

          <% } else if (quiz.status === 'live') { %>
            <div class="mb-4">
              <h4 class="text-info">Live Now! — Question <%= currentNum %> of <%= totalQuestions %></h4>
              <p class="text-light opacity-50">Wait for answers before moving on.</p>
            </div>
            <div class="d-flex justify-content-center gap-3">
              <% if (currentNum < totalQuestions) { %>
                <input type="hidden" name="action" value="next">
                <button type="submit" class="btn btn-primary btn-lg px-4">
                  Next Question <i class="bi bi-arrow-right"></i>
                </button>
              <% } else { %>
                <input type="hidden" name="action" value="next">
                <button type="submit" class="btn btn-danger btn-lg px-4">
                  Finish Quiz &amp; Show Results
                </button>
              <% } %>
            </div>

          <% } else if (quiz.status === 'ended') { %>
            <div class="alert alert-info border-0 glass-card">This quiz has finished.</div>
            <a href="/export-pdf/<%= quiz.id %>" class="btn btn-info px-4 mt-3">
              <i class="bi bi-file-earmark-pdf"></i> Export PDF Report
            </a>
          <% } %>
        </form>
      </div>
    </div>

    <div class="col-md-4">
      <div class="glass-card p-4 h-100">
        <h4 class="mb-4 d-flex justify-content-between align-items-center">
          <span><i class="bi bi-people-fill"></i> Players</span>
          <span class="badge bg-primary rounded-pill"><%= participants.length %></span>
        </h4>
        <div class="list-group list-group-flush bg-transparent">
          <% if (participants.length > 0) { %>
            <% participants.forEach((p, i) => { %>
              <div class="list-group-item bg-transparent text-light border-secondary d-flex justify-content-between align-items-center">
                <div>
                  <span class="me-2 text-warning fw-bold">#<%= i + 1 %></span>
                  <%= p.name %>
                </div>
                <span class="badge bg-secondary rounded-pill"><%= p.score %> pts</span>
              </div>
            <% }); %>
          <% } else { %>
            <div class="text-center p-3 opacity-50">Waiting for players to join...</div>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</div>

<% if (quiz.status !== 'ended') { %>
<script>setTimeout(() => location.reload(), 3000);</script>
<% } %>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
