<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QuizArena - Final Results</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link href="/css/style.css" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
</head>
<body class="bg-gradient text-light min-vh-100 d-flex flex-column align-items-center justify-content-center p-4 overflow-hidden position-relative">

  <div class="glass-card p-4 p-md-5 w-100 text-center" style="max-width:600px;z-index:1;">
    <h1 class="mb-2 fw-bolder text-warning" style="font-size:3rem;">Quiz Completed!</h1>
    <p class="fs-4 mb-4">Well done, <strong><%= name %></strong></p>

    <div class="row g-4 mb-5">
      <div class="col-6">
        <div class="p-3 bg-white bg-opacity-10 rounded shadow">
          <div class="opacity-75 mb-1 text-uppercase fw-bold text-info">Your Score</div>
          <div class="fs-1 fw-bold"><%= score %></div>
        </div>
      </div>
      <div class="col-6">
        <div class="p-3 bg-white bg-opacity-10 rounded shadow">
          <div class="opacity-75 mb-1 text-uppercase fw-bold text-warning">Your Rank</div>
          <div class="fs-1 fw-bold">#<%= rank %></div>
        </div>
      </div>
    </div>

    <% if (rank <= 3) { %>
    <div class="alert bg-success bg-opacity-25 border-success text-white mb-4 fs-5 p-3">
      <i class="bi bi-star-fill text-warning me-2"></i> Incredible! You made it to the podium!
    </div>
    <% } %>

    <h4 class="mb-3 text-start border-bottom pb-2 border-secondary">Top 3 Players</h4>
    <div class="list-group list-group-flush bg-transparent mb-5 text-start">
      <% top3.forEach((p, i) => { %>
        <div class="list-group-item bg-transparent text-light border-0 d-flex justify-content-between align-items-center py-2 px-0">
          <span class="fs-5">
            <strong class="<%= i===0?'text-warning':i===1?'text-secondary':'text-danger' %>">#<%= i+1 %></strong>
            <%= p.name %>
          </span>
          <span class="badge bg-primary fs-6"><%= p.score %> pts</span>
        </div>
      <% }); %>
    </div>

    <a href="/" class="btn btn-primary btn-lg w-100 fw-bold shadow-lg">Return to Home</a>
  </div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const end = Date.now() + 3000;
  (function frame() {
    confetti({ particleCount: 5, angle: 60, spread: 55, origin: { x: 0 }, colors: ['#6c5ce7','#00cec9','#fdcb6e'] });
    confetti({ particleCount: 5, angle: 120, spread: 55, origin: { x: 1 }, colors: ['#6c5ce7','#00cec9','#fdcb6e'] });
    if (Date.now() < end) requestAnimationFrame(frame);
  }());
  <% if (rank === 1) { %>
  setTimeout(() => confetti({ particleCount: 150, spread: 100, origin: { y: 0.6 } }), 1500);
  <% } %>
});
</script>
</body>
</html>
