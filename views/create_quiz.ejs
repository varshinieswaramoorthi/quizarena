<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QuizArena - Create Quiz</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-gradient text-light min-vh-100 pb-5">

<nav class="navbar navbar-expand-lg navbar-dark glass-header mb-4">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/dashboard"><i class="bi bi-controller"></i> QuizArena Admin</a>
    <div class="d-flex align-items-center">
      <a href="/dashboard" class="btn btn-outline-light btn-sm me-2">Back to Dashboard</a>
      <a href="/logout" class="btn btn-outline-light btn-sm">Logout</a>
    </div>
  </div>
</nav>

<div class="container" style="max-width:800px;">
  <div class="glass-card p-4 p-md-5">
    <h2 class="mb-4 text-center">Create New Quiz</h2>
    <form id="quizForm" method="POST" action="/create-quiz">

      <div class="mb-4">
        <label class="form-label fw-bold">Quiz Title</label>
        <input type="text" class="form-control form-control-lg" name="title" required placeholder="e.g. JavaScript Basics">
      </div>

      <hr class="border-secondary my-4">
      <div id="questionsContainer"></div>

      <div class="d-grid gap-2 mb-4">
        <button type="button" class="btn btn-outline-light" onclick="addQuestion()">
          <i class="bi bi-plus-circle"></i> Add Another Question
        </button>
      </div>

      <hr class="border-secondary my-4">
      <button type="submit" class="btn btn-primary btn-lg w-100 fw-bold shadow-lg">Save Quiz</button>
    </form>
  </div>
</div>

<template id="questionTemplate">
  <div class="question-block glass-card p-4 mb-4 position-relative border border-primary border-opacity-25">
    <button type="button" class="btn btn-danger btn-sm position-absolute top-0 end-0 m-3 rounded-circle"
      onclick="this.closest('.question-block').remove()" title="Remove">
      <i class="bi bi-trash"></i>
    </button>
    <h4 class="mb-3">Question <span class="q-number">1</span></h4>
    <div class="mb-3">
      <label class="form-label">Question Text</label>
      <textarea class="form-control" name="questions[{INDEX}][text]" rows="2" required placeholder="What is..."></textarea>
    </div>
    <div class="row g-3 mb-3">
      <div class="col-md-6">
        <label class="form-label">Option 1</label>
        <input type="text" class="form-control" name="questions[{INDEX}][opt1]" required>
      </div>
      <div class="col-md-6">
        <label class="form-label">Option 2</label>
        <input type="text" class="form-control" name="questions[{INDEX}][opt2]" required>
      </div>
      <div class="col-md-6">
        <label class="form-label">Option 3</label>
        <input type="text" class="form-control" name="questions[{INDEX}][opt3]" required>
      </div>
      <div class="col-md-6">
        <label class="form-label">Option 4</label>
        <input type="text" class="form-control" name="questions[{INDEX}][opt4]" required>
      </div>
    </div>
    <div class="row g-3">
      <div class="col-md-6">
        <label class="form-label fw-bold text-success">Correct Option</label>
        <select class="form-select" name="questions[{INDEX}][correct]" required>
          <option value="1">Option 1</option>
          <option value="2">Option 2</option>
          <option value="3">Option 3</option>
          <option value="4">Option 4</option>
        </select>
      </div>
      <div class="col-md-6">
        <label class="form-label">Time Limit (Seconds)</label>
        <select class="form-select" name="questions[{INDEX}][time]">
          <option value="10">10 seconds</option>
          <option value="20">20 seconds</option>
          <option value="30" selected>30 seconds</option>
          <option value="45">45 seconds</option>
          <option value="60">60 seconds</option>
        </select>
      </div>
    </div>
  </div>
</template>

<script>
let qIndex = 0;
function addQuestion() {
  const tmpl = document.getElementById('questionTemplate').innerHTML;
  const container = document.getElementById('questionsContainer');
  const div = document.createElement('div');
  div.innerHTML = tmpl.replace(/{INDEX}/g, qIndex);
  container.appendChild(div.firstElementChild);
  updateQuestionNumbers();
  qIndex++;
}
function updateQuestionNumbers() {
  document.querySelectorAll('.question-block').forEach((b, i) => {
    b.querySelector('.q-number').textContent = i + 1;
  });
}
document.addEventListener('DOMContentLoaded', addQuestion);
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
