<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QuizArena - Leaderboard</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body class="bg-gradient text-light min-vh-100 d-flex flex-column align-items-center justify-content-center p-4">
  <div class="glass-card p-4 p-md-5 w-100" style="max-width:600px;">
    <div class="text-center mb-4">
      <i class="bi bi-trophy text-warning" style="font-size:4rem;"></i>
      <h2 class="mt-2 fw-bold">Live Standings</h2>
      <p class="fs-5 opacity-75"><%= quiz.quiz_title %></p>
    </div>
    <div class="list-group list-group-flush bg-transparent rounded">
      <% participants.forEach((p, i) => { %>
        <% const colorClass = i===0?'text-warning':i===1?'text-secondary':i===2?'text-danger':'text-light'; %>
        <% const icon = i===0?'<i class="bi bi-award-fill"></i>':i<3?'<i class="bi bi-award"></i>':''; %>
        <div class="list-group-item bg-transparent <%= colorClass %> border-light border-opacity-10 d-flex justify-content-between align-items-center fs-5 py-3">
          <div>
            <span class="me-3 fw-bold opacity-75">#<%= i+1 %></span>
            <span class="fw-bold"><%= p.name %> <%- icon %></span>
          </div>
          <span class="badge bg-primary rounded-pill fs-6"><%= p.score %> pts</span>
        </div>
      <% }); %>
    </div>
    <% if (hasParticipantSession) { %>
    <div class="mt-4 text-center">
      <a href="/quiz" class="btn btn-outline-light">Back to Game</a>
    </div>
    <% } %>
  </div>

  <% if (quiz.status !== 'ended') { %>
  <script>setTimeout(() => location.reload(), 5000);</script>
  <% } %>
</body>
</html>
