<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>QuizArena - Live Game</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
  <link href="/css/style.css" rel="stylesheet">
  <script>const QUIZ_CODE = "<%= quizCode %>";</script>
</head>
<body class="bg-gradient text-light min-vh-100 d-flex flex-column">

  <div class="glass-header w-100 p-3 d-flex justify-content-between align-items-center">
    <div>
      <i class="bi bi-person-circle text-info fs-4 me-2"></i>
      <span class="fs-5 fw-bold"><%= name %></span>
    </div>
    <div>
      <span class="badge bg-warning text-dark fs-5">Score: <span id="scoreDisplay"><%= score %></span></span>
    </div>
  </div>

  <div class="container flex-grow-1 d-flex flex-column justify-content-center align-items-center p-4">

    <!-- Waiting Screen -->
    <div id="waitingScreen" class="text-center w-100" style="max-width:600px;">
      <div class="spinner-grow text-info" style="width:4rem;height:4rem;" role="status"></div>
      <h2 class="mt-4" id="waitingText">Waiting for the host to start the game...</h2>
      <p class="fs-5 opacity-75 mt-3">Get ready! The faster you answer, the more points you earn.</p>
    </div>

    <!-- Question Screen -->
    <div id="questionScreen" class="w-100 d-none" style="max-width:800px;">
      <div class="glass-card p-4 p-md-5 w-100">
        <div class="d-flex justify-content-between align-items-center mb-4">
          <span class="badge bg-secondary fs-6">Question <span id="qNum">1</span> of <span id="qTotal">10</span></span>
          <div class="timer-circle text-warning shadow-lg" id="timerDisplay">30</div>
        </div>
        <h3 class="mb-5 text-center fw-bold lh-base" id="questionText">Loading...</h3>
        <div class="row g-4" id="optionsContainer">
          <% [['A',1],['B',2],['C',3],['D',4]].forEach(([letter, num]) => { %>
          <div class="col-md-6">
            <button class="btn w-100 py-4 fs-5 fw-bold quiz-option text-start d-flex align-items-center shadow-lg"
              onclick="selectOption(this, <%= num %>)">
              <span class="badge bg-light text-dark rounded-circle p-2 me-3 d-flex align-items-center justify-content-center" style="width:32px;height:32px;"><%= letter %></span>
              <span class="w-100 text-center" id="opt<%= num %>Text">Option <%= num %></span>
            </button>
          </div>
          <% }); %>
        </div>
      </div>
    </div>

    <!-- Feedback Screen -->
    <div id="feedbackScreen" class="w-100 d-none text-center" style="max-width:600px;">
      <div class="glass-card p-5">
        <div id="feedbackIcon" class="mb-4"></div>
        <h2 id="feedbackTitle" class="mb-3 fw-bold">Correct!</h2>
        <h4 class="mb-4 text-warning">+<span id="feedbackPoints">850</span> points</h4>
        <p class="fs-5 opacity-75">Waiting for others to finish...</p>
        <div class="spinner-border text-light mt-3" role="status"></div>
      </div>
    </div>

  </div>

<script src="/js/main.js"></script>
</body>
</html>
