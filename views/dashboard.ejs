<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QuizArena - Admin Dashboard</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #4f46e5;
            --secondary: #7c3aed;
            --dark: #0f172a;
            --sidebar: #1e293b;
            --light: #f1f5f9;
            --white: #ffffff;
            --danger: #ef4444;
            --success: #10b981;
        }

        body { margin: 0; font-family: 'Poppins', sans-serif; background: var(--light); color: var(--dark); display: flex; height: 100vh; overflow: hidden; }
        
        .sidebar {
            width: 250px;
            background: var(--sidebar);
            color: #fff;
            display: flex;
            flex-direction: column;
            padding-top: 20px;
        }

        .sidebar h2 { text-align: center; color: #38bdf8; letter-spacing: 1px; margin-bottom: 30px; }
        .sidebar a {
            padding: 15px 25px;
            color: #cbd5e1;
            text-decoration: none;
            font-weight: 500;
            display: block;
            transition: all 0.3s;
            border-left: 4px solid transparent;
        }
        .sidebar a:hover, .sidebar a.active {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border-left: 4px solid #38bdf8;
        }
        
        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }

        .topbar {
            background: var(--white);
            padding: 15px 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            z-index: 10;
        }

        .topbar .user-info { font-weight: 600; }
        .btn-logout { background: var(--danger); color: white; border: none; padding: 8px 15px; border-radius: 6px; cursor: pointer; text-decoration: none; font-size: 14px; }

        .container { padding: 30px; }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .stat-card {
            background: var(--white);
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
            border-bottom: 4px solid var(--primary);
        }
        .stat-card h4 { margin: 0; color: #64748b; font-size: 14px; text-transform: uppercase; }
        .stat-card h2 { margin: 10px 0 0 0; font-size: 32px; color: var(--dark); }

        .table-container {
            background: var(--white);
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.05);
        }

        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 15px; text-align: left; border-bottom: 1px solid #e2e8f0; }
        th { color: #64748b; font-weight: 600; }
        
        .badge { padding: 5px 10px; border-radius: 20px; font-size: 12px; font-weight: 600; color: #fff; }
        .badge.pending { background: #f59e0b; }
        .badge.live { background: var(--success); }
        .badge.ended { background: #64748b; }

        .actions button, .actions a {
            padding: 6px 12px;
            border: none;
            border-radius: 5px;
            color: #fff;
            cursor: pointer;
            font-size: 12px;
            font-family: 'Poppins', sans-serif;
            text-decoration: none;
            margin-right: 5px;
        }

        .btn-host { background: var(--primary); }
        .btn-rehost { background: #8b5cf6; }
        .btn-report { background: #0ea5e9; }
        .btn-delete { background: var(--danger); }
    </style>
</head>
<body>

    <div class="sidebar">
        <h2>QuizArena</h2>
        <a href="/dashboard" class="active">Dashboard</a>
        <a href="#">Create Quiz</a>
        <a href="#">Host Quiz</a>
        <a href="#">Rehost Quiz</a>
        <a href="#">Reports</a>
        <a href="/logout" style="margin-top:auto">Logout</a>
    </div>

    <div class="main-content">
        <div class="topbar">
            <div class="user-info">Logged in as: <%= admin.username %></div>
            <a href="/logout" class="btn-logout">Logout</a>
        </div>

        <div class="container">
            <div class="stats-grid">
                <div class="stat-card" style="border-color: #3b82f6">
                    <h4>Total Quizzes</h4>
                    <h2><%= stats.totalQuizzes %></h2>
                </div>
                <div class="stat-card" style="border-color: #10b981">
                    <h4>Live Quizzes</h4>
                    <h2><%= stats.liveQuizzes %></h2>
                </div>
                <div class="stat-card" style="border-color: #f59e0b">
                    <h4>Total Participants</h4>
                    <h2><%= stats.totalParticipants %></h2>
                </div>
                <div class="stat-card" style="border-color: #64748b">
                    <h4>Finished Quizzes</h4>
                    <h2><%= stats.finishedQuizzes %></h2>
                </div>
            </div>

            <div class="table-container">
                <h3 style="margin-top:0">Manage Quizzes</h3>
                <table>
                    <thead>
                        <tr>
                            <th>Quiz Title</th>
                            <th>Code</th>
                            <th>Status</th>
                            <th>Participants</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(quizzes.length === 0) { %>
                            <tr><td colspan="5" style="text-align:center">No quizzes found.</td></tr>
                        <% } else { %>
                            <% quizzes.forEach(q => { %>
                                <tr>
                                    <td><strong><%= q.title %></strong></td>
                                    <td><code><%= q.code %></code></td>
                                    <td><span class="badge <%= q.status %>"><%= q.status.toUpperCase() %></span></td>
                                    <td><%= q.participantCount %></td>
                                    <td class="actions">
                                        <% if(q.status === 'pending') { %>
                                            <button class="btn-host" onclick="changeStatus('<%= q.id %>', 'live')">Host</button>
                                        <% } else if(q.status === 'live' || q.status === 'ended') { %>
                                            <button class="btn-rehost" onclick="changeStatus('<%= q.id %>', 'live')">Rehost</button>
                                        <% } %>
                                        
                                        <% if(q.status === 'ended' || q.participantCount > 0) { %>
                                            <a href="/report/<%= q.code %>" target="_blank" class="btn-report">View Report</a>
                                        <% } %>
                                        <button class="btn-delete" onclick="deleteQuiz('<%= q.id %>')">Delete</button>
                                    </td>
                                </tr>
                            <% }); %>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        async function changeStatus(id, newStatus) {
            const res = await fetch(`/api/admin/quiz/${id}/status`, {
                method: 'POST',
                headers: {'Content-Type': 'application/json'},
                body: JSON.stringify({ status: newStatus })
            });
            if(res.ok) window.location.reload();
            else alert('Failed to change status');
        }

        async function deleteQuiz(id) {
            if(!confirm('Are you sure you want to delete this quiz?')) return;
            const res = await fetch(`/api/admin/quiz/${id}`, { method: 'DELETE' });
            if(res.ok) window.location.reload();
            else alert('Failed to delete query');
        }
    </script>
</body>
</html>
