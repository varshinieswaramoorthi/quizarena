# ================================================
# QuizArena - Environment Variables
# ================================================
# Copy this file to .env for local development
# Set these as Environment Variables in Render dashboard

# Supabase credentials (get from supabase.com > Project Settings > API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Session secret (use a long random string in production)
SESSION_SECRET=change-this-to-a-long-random-secret-string

# Your app's public URL (used in host view for display)
APP_URL=https://your-app-name.onrender.com

# Node environment
NODE_ENV=production

# Port (Render sets this automatically - don't change)
# PORT=3000
